# Supabase (проект Marketing agency, схема content_creation_agent)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Redis (общий контейнер агентов; localhost при запуске вне Docker, redis://redis:6379 внутри Docker)
REDIS_URL=

# Cloudflare R2 (хранилище сгенерированных файлов — не Supabase Storage, см. «04. Брейншторм», §6)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Генерация текста (Слайс 2) — тот же общий OpenRouter-аккаунт, что и у Агентов 1/2/3
OPENROUTER_API_KEY=

# Наблюдаемость — Helicone (прокси-логирование LLM-вызовов). Опционально: без
# этой переменной агент работает как раньше, без прокси.
HELICONE_API_KEY=

# Генерация изображений (Слайс 4) — Runway text_to_image, gen4_image_turbo -> gen4_image
RUNWAY_API_KEY=

# Генерация видео (Слайс 5, оба тира) — MiniMax Hailuo-02 (768P) -> Hailuo-2.3 (1080P).
# НЕ Runway: у Runway видео доступно только как image_to_video (обязателен исходный
# кадр), не подходит для чистого текстового промпта. НЕ Sora 2: API объявлен
# deprecated, отключается 24 сентября 2026 — см. «08. Задачник», Слайс 5.
MINIMAX_API_KEY=

# Не подключено в коде (не входят в текущий каскад Слайса 4 — только Runway).
# Задел на будущее по «05. ТЗ», §4.1, если понадобится альтернативный тир изображений.
IDEOGRAM_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=

# Генерация озвучки (Слайс 6) — дешёвый тир
DEEPGRAM_API_KEY=

# Генерация озвучки (Слайс 6) — основной тир, фирменный/клонированный голос бренда
ELEVENLABS_API_KEY=
# ID голоса ElevenLabs (обязателен, дефолта нет — клонирование голоса бренда ещё не
# настроено; см. Get voices: elevenlabs.io/docs/api-reference/voices/search)
ELEVENLABS_VOICE_ID=

# Резерв открытых моделей
REPLICATE_API_KEY=

# Публикация
POSTMYPOST_API_KEY=

# MCP-сервер Агента 3 (выход) — обогащение трендовыми данными по требованию
INFORMATION_ANALYSIS_AGENT_URL=

# MCP-сервер этого агента (выход) — Streamable HTTP, порт по умолчанию 7303
MCP_HTTP_PORT=
