# Supabase (проект Marketing agency, схема content_creation_agent)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Redis (общий контейнер агентов; localhost при запуске вне Docker, redis://redis:6379 внутри Docker)
REDIS_URL=

# Cloudflare R2 (хранилище сгенерированных файлов — не Supabase Storage, см. «04. Брейншторм», §6)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Генерация текста (Слайс 2) — тот же общий OpenRouter-аккаунт, что и у Агентов 1/2/3
OPENROUTER_API_KEY=

# Наблюдаемость — Helicone (прокси-логирование LLM-вызовов). Опционально: без
# этой переменной агент работает как раньше, без прокси.
HELICONE_API_KEY=

# Генерация — видео/часть изображений (агрегатор Gen-4.5/Veo 3.1/Gemini Image3/GPT-Image-2)
RUNWAY_API_KEY=

# Генерация — дешёвое видео (черновики)
MINIMAX_API_KEY=

# Генерация — изображения (текст на картинке, Character Reference)
IDEOGRAM_API_KEY=

# Генерация — изображения (баланс цена/качество)
GOOGLE_AI_STUDIO_API_KEY=

# Генерация — голос, черновики
DEEPGRAM_API_KEY=

# Генерация — голос, финал/клон бренда
ELEVENLABS_API_KEY=

# Резерв открытых моделей
REPLICATE_API_KEY=

# Публикация
POSTMYPOST_API_KEY=

# MCP-сервер Агента 3 (выход) — обогащение трендовыми данными по требованию
INFORMATION_ANALYSIS_AGENT_URL=

# MCP-сервер этого агента (выход) — Streamable HTTP, порт по умолчанию 7303
MCP_HTTP_PORT=
